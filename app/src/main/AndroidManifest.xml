<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- THIS IS THE LINE YOU MUST ADD -->
    <uses-permission android:name="android.permission.INTERNET" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WeatherApp"
        tools:targetApi="31">

        <!-- MainActivity2 is now the entry point of the app -->
        <activity
            android:name=".MainActivity2"
            android:exported="true">  <!-- Launcher activity must be exported -->
            <!-- The intent-filter is now correctly placed inside the activity -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity is a regular activity, not the entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="false"> <!-- Should be false unless opened by other apps -->
        </activity>

    </application>

</manifest>
